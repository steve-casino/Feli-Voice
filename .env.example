# Anthropic
ANTHROPIC_API_KEY=

# Deepgram
DEEPGRAM_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Telnyx
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_PHONE_NUMBER=
TELNYX_CONNECTION_ID=

# Google (Calendar / Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# Outbound dialer (tools/dialer.py + OpenClaw agent)
# GOOGLE_SHEETS_ID: the long id from the call-list sheet URL
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# GOOGLE_SERVICE_ACCOUNT_FILE: path to a service-account JSON key. Create the
#   service account in Google Cloud, enable the Sheets API, then SHARE the
#   sheet with the service account's client_email (Editor).
# FELI_APP_URL: where the voice app listens (the dialer POSTs /calls/outbound).
# HANGUP_SPOOL_PATH: where the voice app appends Telnyx call.hangup events.
#   tools/dialer.py drains this into the sheet on each run. Default sits next
#   to the OpenClaw wrapper so it's covered by the same TCC grant on macOS.
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
FELI_APP_URL=http://localhost:8000
HANGUP_SPOOL_PATH=~/Library/Application Support/felicetti-voice/hangups.jsonl

# App
APP_HOST=0.0.0.0
APP_PORT=8000
# Public URL that Telnyx hits, e.g. https://api.felivoice.com.
# Used to build wss://api.felivoice.com/telnyx/media for media streaming.
APP_BASE_URL=
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./feli_voice_agent.db
